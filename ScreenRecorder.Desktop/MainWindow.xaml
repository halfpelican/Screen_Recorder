<Window x:Class="ScreenRecorder.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Recorder"
        Width="720"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushText}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="⏺ Screen Recorder"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource BrushAccent}"
                   Margin="0,0,0,16" />

        <Border Grid.Row="1"
                Background="{StaticResource BrushPanel}"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Output file:"
                           Foreground="{StaticResource BrushTextMuted}" />
                <Grid Grid.Row="0"
                      Grid.Column="1"
                      Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="OutputPathTextBox"
                             Grid.Column="0"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Background="#0f3460"
                             Foreground="{StaticResource BrushText}"
                             BorderThickness="0"
                             Padding="8,0" />
                    <Button x:Name="BrowseButton"
                            Grid.Column="1"
                            Content="Browse"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Background="#0f3460"
                            Foreground="{StaticResource BrushText}"
                            BorderThickness="0"
                            Click="BrowseButton_Click" />
                </Grid>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="FPS:"
                           Foreground="{StaticResource BrushTextMuted}" />
                <ComboBox x:Name="FpsComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Height="30"
                          Width="140"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,10"
                          Background="#0f3460"
                          Foreground="{StaticResource BrushText}"
                          BorderThickness="0" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Capture region:"
                           Foreground="{StaticResource BrushTextMuted}" />
                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <TextBlock x:Name="RegionTextBlock"
                               Text="Full screen"
                               Width="250"
                               VerticalAlignment="Center" />
                    <Button Content="Select region"
                            Click="SelectRegionButton_Click"
                            Margin="0,0,8,0"
                            Padding="12,6"
                            Background="#0f3460"
                            Foreground="{StaticResource BrushText}"
                            BorderThickness="0" />
                    <Button Content="Reset"
                            Click="ResetRegionButton_Click"
                            Padding="12,6"
                            Background="#0f3460"
                            Foreground="{StaticResource BrushTextMuted}"
                            BorderThickness="0" />
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Audio source:"
                           Foreground="{StaticResource BrushTextMuted}" />
                <ComboBox x:Name="AudioSourceComboBox"
                          Grid.Row="3"
                          Grid.Column="1"
                          Height="30"
                          Width="260"
                          HorizontalAlignment="Left"
                          Background="#0f3460"
                          Foreground="{StaticResource BrushText}"
                          BorderThickness="0" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,12">
            <TextBlock x:Name="TimerTextBlock"
                       Text="00:00"
                       FontSize="42"
                       FontFamily="Consolas"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrushAccent}"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusTextBlock"
                       Text="Ready"
                       Foreground="{StaticResource BrushTextMuted}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <Button x:Name="StartButton"
                    Content="▶ Start Recording"
                    Click="StartButton_Click"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    FontWeight="Bold"
                    Background="{StaticResource BrushAccent}"
                    Foreground="Black"
                    BorderThickness="0" />
            <Button x:Name="StopButton"
                    Content="■ Stop"
                    Click="StopButton_Click"
                    Padding="20,10"
                    FontWeight="Bold"
                    Background="{StaticResource BrushDanger}"
                    Foreground="White"
                    BorderThickness="0"
                    IsEnabled="False" />
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Margin="0,8,0,0"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource BrushTextMuted}"
                   Text="Windows Graphics Capture + WASAPI + Media Foundation (SharpAvi fallback)" />
    </Grid>
</Window>
