<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.275">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Windows.SDK.Win32Metadata" Version="70.0.11-preview" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="SharpAvi" Version="2.*" />
    <PackageReference Include="Vortice.Direct3D11" Version="3.*" />
    <PackageReference Include="Vortice.DXGI" Version="3.*" />
  </ItemGroup>

</Project>
