<Application x:Class="ScreenRecorder.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!--
            Color values are inlined directly into each brush.
            The original design used {StaticResource ColorX} inside Application.Resources
            to set SolidColorBrush.Color — WPF's XAML parser can fail to resolve those
            self-referential lookups during startup in .NET 8, producing a
            XamlParseException ("Provide value on StaticResourceHolder threw an exception").
            Inlining eliminates the dependency chain entirely.
        -->
        <SolidColorBrush x:Key="BrushBackground" Color="#1a1a2e" />
        <SolidColorBrush x:Key="BrushPanel"      Color="#16213e" />
        <SolidColorBrush x:Key="BrushAccent"     Color="#00FF88" />
        <SolidColorBrush x:Key="BrushDanger"     Color="#ff4757" />
        <SolidColorBrush x:Key="BrushText"       Color="#e0e0e0" />
        <SolidColorBrush x:Key="BrushTextMuted"  Color="#888888" />
    </Application.Resources>
</Application>
